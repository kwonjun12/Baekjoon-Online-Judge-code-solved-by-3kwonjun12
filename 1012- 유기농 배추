#include <stdio.h>
#include <stdlib.h>
#include <queue>

using namespace std;

int dx[4] = {0, 0, -1, 1};
int dy[4] = {-1, 1, 0, 0};

typedef struct{
   int y, x;
}yx;

int main(void){
    int t;
    scanf("%d", &t);
    while(t--){
        int m, n, k;
        scanf("%d %d %d", &m, &n, &k);
        yx c[k];
        for(int i = 0; i < k; i++){
           scanf("%d %d", &c[i].x, &c[i].y); 
        }
        int f[50][50] = {0}; 
        for(int i = 0; i < k; i++){
            f[c[i].y][c[i].x] = 1;
        }
        int ans = 0;
        queue<yx> q;
        for(int i = 0; i < n; i++){
            for(int j = 0; j < m; j++){
                if(f[i][j]){
                    ans++;
                    f[i][j] = 0;
                    q.push({i, j});
                    while(!q.empty()){
                        yx h = q.front();  
                        q.pop();
                        for(int d = 0; d < 4; d++){
                            int ny = h.y + dy[d];
                            int nx = h.x + dx[d];
                            if(ny >= 0 && ny < n && nx >= 0 && nx < m && f[ny][nx]){
                                f[ny][nx] = 0;
                                q.push({ny, nx});
                            }
                        }
                    }
                }
            }
        }
        printf("%d\n", ans);
    }
}
